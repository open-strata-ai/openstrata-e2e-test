# OpenStrata E2E Test — shared Docker Compose environment variables.

# Postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Eval service
EVAL_MODE=production
PGDSN=postgresql://eval_user:eval@postgres:5432/eval?sslmode=disable

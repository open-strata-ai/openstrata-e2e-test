# OpenStrata cross-repo integration smoke test — port map.
# Resolves the historical doc conflict (aictl default 8080 vs platform-api 8081):
# every service gets a distinct, explicit port; the CLI talks to ONE proxy port.
# ROOT is the workspace root containing all 18+ OpenStrata repos (sibling to this repo).
# Default: grandparent of $SMOKE (the e2e-test repo root's parent).
# Override via env:  export ROOT=/path/to/workspace
ROOT="${ROOT:-$(cd "$(dirname "$(dirname "${SMOKE}")")" && pwd)}"

RESOLVER_PORT=8090
PROVISIONER_PORT=8091
GATEWAY_PORT=8092
TOOL_REGISTRY_PORT=8093
SANDBOX_PORT=8094
EVAL_PORT=8000
PROXY_PORT=8079
PLATFORM_PORT=8081
ADMIN_PORT=8088

RESOLVER_URL=http://localhost:${RESOLVER_PORT}
PROVISIONER_URL=http://localhost:${PROVISIONER_PORT}
GATEWAY_URL=http://localhost:${GATEWAY_PORT}
TOOL_REGISTRY_URL=http://localhost:${TOOL_REGISTRY_PORT}
SANDBOX_URL=http://localhost:${SANDBOX_PORT}
EVAL_URL=http://localhost:${EVAL_PORT}
PROXY_URL=http://localhost:${PROXY_PORT}
PLATFORM_URL=http://localhost:${PLATFORM_PORT}
ADMIN_URL=http://localhost:${ADMIN_PORT}
